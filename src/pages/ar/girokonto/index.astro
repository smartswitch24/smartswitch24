---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FinanceDisclaimer from '../../../components/FinanceDisclaimer.astro';
import TrustBar from '../../../components/TrustBar.astro';
import FaqList from '../../../components/FaqList.astro';
import CalculatorEmbed from '../../../components/CalculatorEmbed.astro';
import { ar as t } from '../../../i18n/ar';
import { girokontoWidget } from '../../../config/affiliate-widgets';

const lang = 'ar';
const siteUrl = 'https://smartswitch24.de';
const canonical = `${siteUrl}/ar/girokonto/`;
const alternateUrl = `${siteUrl}/de/girokonto/`;
const faqs = [
  { q: t.girokonto_faq1_q, a: t.girokonto_faq1_a },
  { q: t.girokonto_faq2_q, a: t.girokonto_faq2_a },
];
---
<BaseLayout title={t.girokonto_meta_title} description={t.girokonto_meta_description} lang={lang} canonical={canonical} alternateUrl={alternateUrl}>
  <Header lang={lang} activePage="finanzen" />
  <FinanceDisclaimer lang={lang} />
  <div class="page-header">
    <div class="container">
      <h1>{t.girokonto_page_title}</h1>
      <p>{t.girokonto_page_subtitle}</p>
    </div>
  </div>
  <CalculatorEmbed
    lang={lang}
    title={girokontoWidget.titleAr}
    description={girokontoWidget.descriptionAr}
    providerName={girokontoWidget.providerName}
    htmlCode={girokontoWidget.htmlCode}
    disclaimer={girokontoWidget.disclaimerAr}
  />
  <section>
    <div class="container">
      <FaqList title={t.girokonto_faq_title} items={faqs} />
      <p style="margin-top:24px;"><a href="/ar/finanzen/" style="color:var(--color-primary);">← للعودة إلى الشؤون المالية</a></p>
    </div>
  </section>
  <TrustBar lang={lang} />
  <Footer lang={lang} />
</BaseLayout>
