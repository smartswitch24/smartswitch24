---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import TrustBar from '../../../components/TrustBar.astro';
import { de as t } from '../../../i18n/de';

const lang = 'de';
const siteUrl = 'https://smartswitch24.de';
const canonical = `${siteUrl}/de/blog/`;
const alternateUrl = `${siteUrl}/ar/blog/`;

const allPosts = await getCollection('blog', ({ data }) =>
  data.lang === 'de' && !data.draft,
);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const catLabel: Record<string, string> = {
  strom: 'Strom & Energie', gas: 'Gas', handy: 'Handy & Tarife',
  smartphones: 'Smartphones', tablets: 'Tablets', smartwatches: 'Smartwatches',
  reisen: 'Reisen', finanzen: 'Finanzen', ratgeber: 'Ratgeber',
};

const catColor: Record<string, string> = {
  strom: '#1a3a6b', gas: '#0d6e6e', handy: '#6b3a1a',
  reisen: '#1a6b3a', finanzen: '#3a1a6b', ratgeber: '#555',
};

const catIcon: Record<string, string> = {
  strom:       `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M13 2 3 14h9l-1 8 10-12h-9z"/></svg>`,
  gas:         `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M12 2C9 6 6 10 6 14a6 6 0 0 0 12 0c0-4-3-8-6-12zm0 16a2 2 0 0 1-2-2c0-1.5 2-4 2-4s2 2.5 2 4a2 2 0 0 1-2 2z"/></svg>`,
  handy:       `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M17 1H7c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-2-2-2zm0 18H7V5h10v14z"/></svg>`,
  smartphones: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M17 1H7c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-2-2-2zm0 18H7V5h10v14z"/></svg>`,
  tablets:     `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M18.5 2h-14C3.1 2 2 3.1 2 4.5v15C2 20.9 3.1 22 4.5 22h14c1.4 0 2.5-1.1 2.5-2.5v-15C21 3.1 19.9 2 18.5 2zM12 20c-.8 0-1.5-.7-1.5-1.5S11.2 17 12 17s1.5.7 1.5 1.5S12.8 20 12 20zm6-4H6V5h12v11z"/></svg>`,
  smartwatches:`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M20 12a8 8 0 1 0-16 0 8 8 0 0 0 16 0zm-8 5a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm.5-8H11v4.25l3.25 1.95-.75 1.25L10 14.3V9h2.5z"/></svg>`,
  reisen:      `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5z"/></svg>`,
  finanzen:    `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M5 9.2h3V19H5zm5.6-4.2h2.8v14h-2.8zm5.6 8h2.8V19h-2.8z"/></svg>`,
  ratgeber:    `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>`,
};
---
<BaseLayout title={t.blog_meta_title} description={t.blog_meta_description} lang={lang} canonical={canonical} alternateUrl={alternateUrl}>
  <Header lang={lang} activePage="blog" />

  <div class="page-header">
    <div class="container">
      <h1>{t.blog_page_title}</h1>
      <p>{t.blog_page_subtitle}</p>
    </div>
  </div>

  <section>
    <div class="container">
      {posts.length === 0 ? (
        <p style="color:var(--color-text-light);">{t.blog_coming_soon}</p>
      ) : (
        <div class="blog-grid">
          {posts.map(post => {
            const slug = post.slug.split('/').pop();
            const cat = catLabel[post.data.category] ?? post.data.category;
            const color = catColor[post.data.category] ?? 'var(--color-primary)';
            const date = post.data.pubDate.toLocaleDateString('de-DE', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            return (
              <a href={`/de/blog/${slug}/`} class="blog-card">
                <div class="blog-card__cat" style={`background:${color};`}>
                  <Fragment set:html={catIcon[post.data.category] ?? ''} />
                  {cat}
                </div>
                <div class="blog-card__body">
                  <h2 class="blog-card__title">{post.data.title}</h2>
                  <p class="blog-card__desc">{post.data.description}</p>
                </div>
                <div class="blog-card__footer">
                  <time>{date}</time>
                  <span class="blog-card__read">Weiterlesen →</span>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <TrustBar lang={lang} />
  <Footer lang={lang} />
</BaseLayout>

<style>
  .blog-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    margin-top: 8px;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .blog-card:hover {
    box-shadow: 0 8px 32px rgba(26,46,74,0.14);
    transform: translateY(-3px);
    text-decoration: none;
  }

  .blog-card__cat {
    padding: 6px 16px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .blog-card__body {
    padding: 20px 20px 12px;
    flex: 1;
  }

  .blog-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 8px;
    line-height: 1.35;
  }

  .blog-card__desc {
    font-size: 0.88rem;
    color: var(--color-text-light);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__footer {
    padding: 12px 20px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-border);
    font-size: 0.82rem;
    color: var(--color-text-light);
  }

  .blog-card__read {
    color: var(--color-accent);
    font-weight: 700;
  }
</style>
