---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AffiliateNotice from '../../../components/AffiliateNotice.astro';
import TrustBar from '../../../components/TrustBar.astro';
import FaqList from '../../../components/FaqList.astro';
import CalculatorEmbed from '../../../components/CalculatorEmbed.astro';
import { de as t } from '../../../i18n/de';
import { pauschalreisenWidget } from '../../../config/affiliate-widgets';

const lang = 'de';
const siteUrl = 'https://smartswitch24.de';
const canonical = `${siteUrl}/de/all-inclusive/`;
const alternateUrl = `${siteUrl}/ar/all-inclusive/`;
const faqs = [
  { q: t.all_inclusive_faq1_q, a: t.all_inclusive_faq1_a },
  { q: t.all_inclusive_faq2_q, a: t.all_inclusive_faq2_a },
];
---
<BaseLayout title={t.all_inclusive_meta_title} description={t.all_inclusive_meta_description} lang={lang} canonical={canonical} alternateUrl={alternateUrl}>
  <Header lang={lang} activePage="pauschalreisen" />
  <AffiliateNotice lang={lang} variant="short" />
  <div class="page-header">
    <div class="container">
      <h1>{t.all_inclusive_page_title}</h1>
      <p>{t.all_inclusive_page_subtitle}</p>
    </div>
  </div>
  <CalculatorEmbed lang={lang} title={pauschalreisenWidget.titleDe} providerName={pauschalreisenWidget.providerName} htmlCode={pauschalreisenWidget.htmlCode} disclaimer={pauschalreisenWidget.disclaimerDe} />
  <section>
    <div class="container">
      <FaqList title={t.all_inclusive_faq_title} items={faqs} />
      <p style="margin-top:24px;"><a href="/de/pauschalreisen/" style="color:var(--color-primary);">← Zurück zu Pauschalreisen</a></p>
    </div>
  </section>
  <TrustBar lang={lang} />
  <Footer lang={lang} />
</BaseLayout>
