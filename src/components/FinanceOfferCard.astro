---
import type { FinanceOffer } from '../config/affiliate-widgets';

interface Props {
  offer: FinanceOffer;
  lang: 'de' | 'ar';
}
const { offer, lang } = Astro.props;
const benefits = lang === 'de' ? offer.benefitsDe : offer.benefitsAr;
const cta = lang === 'de' ? offer.ctaDe : offer.ctaAr;
const updatedLabel = lang === 'de' ? 'Zuletzt aktualisiert' : 'آخر تحديث';
---
<div class="offer-card">
  {offer.providerLogo && (
    <img src={offer.providerLogo} alt={offer.providerName} width="120" height="40" style="object-fit:contain;max-height:40px;" />
  )}
  <div class="offer-card__provider">{offer.providerName}</div>
  <div style="font-weight:700;color:var(--color-text);font-size:1rem;">{offer.productName}</div>
  <div class="offer-card__price">{offer.monthlyCost}</div>
  {offer.bonusOrInterest && (
    <div style="background:var(--color-surface);padding:6px 10px;border-radius:var(--radius);font-size:.88rem;font-weight:600;color:var(--color-primary);">
      {offer.bonusOrInterest}
    </div>
  )}
  {benefits.length > 0 && (
    <ul class="offer-card__benefits">
      {benefits.map(b => <li>{b}</li>)}
    </ul>
  )}
  {offer.affiliateUrl ? (
    <a href={offer.affiliateUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer sponsored">{cta}</a>
  ) : (
    <span class="btn btn-primary" style="opacity:.5;cursor:default;">{cta}</span>
  )}
  {offer.lastUpdated && (
    <p class="offer-card__updated">{updatedLabel}: {offer.lastUpdated}</p>
  )}
</div>
