---
interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  items: FaqItem[];
  title?: string;
}
const { items, title } = Astro.props;
---
{title && <h2 class="section-title">{title}</h2>}
<div class="faq-list">
  {items.map(item => (
    <details class="faq-item">
      <summary>{item.q}</summary>
      <p>{item.a}</p>
    </details>
  ))}
</div>
